rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is authenticated as the system user
    function isSystemServer() {
      return request.auth != null && request.auth.token.email == 'system@maissy.com';
    }

    // ID validation helper to prevent ID character poisoning or malicious document keys
    function isValidId(id) {
      // Allow letters, numbers, hyphens, underscores, colons, dots, and plus signs (for timestamps/special IDs)
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-:\\.\\+]+$');
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if (isSystemServer() || request.auth == null) && isValidId(userId);
      allow list: if isSystemServer() || request.auth == null;
      allow write: if (isSystemServer() || request.auth == null) && isValidId(userId);
    }

    // 2. Menus Collection
    match /menus/{menuId} {
      allow get: if (isSystemServer() || request.auth == null) && isValidId(menuId);
      allow list: if isSystemServer() || request.auth == null;
      allow write: if (isSystemServer() || request.auth == null) && isValidId(menuId);
    }

    // 3. Transactions Collection
    match /transactions/{transactionId} {
      allow get: if (isSystemServer() || request.auth == null) && isValidId(transactionId);
      allow list: if isSystemServer() || request.auth == null;
      allow write: if (isSystemServer() || request.auth == null) && isValidId(transactionId);
    }

    // 4. Transaction Details Collection
    match /transaction_details/{detailId} {
      allow get: if (isSystemServer() || request.auth == null) && isValidId(detailId);
      allow list: if isSystemServer() || request.auth == null;
      allow write: if (isSystemServer() || request.auth == null) && isValidId(detailId);
    }

    // 5. Activity Logs Collection
    match /activity_log/{logId} {
      allow get: if (isSystemServer() || request.auth == null) && isValidId(logId);
      allow list: if isSystemServer() || request.auth == null;
      allow write: if (isSystemServer() || request.auth == null) && isValidId(logId);
    }

    // 6. Settings Collection
    match /settings/{settingsId} {
      allow get: if (isSystemServer() || request.auth == null) && isValidId(settingsId);
      allow list: if isSystemServer() || request.auth == null;
      allow write: if (isSystemServer() || request.auth == null) && isValidId(settingsId);
    }
  }
}

