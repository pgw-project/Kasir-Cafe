rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ID validation helper to prevent ID character poisoning or malicious document keys
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read, write: if isValidId(userId);
    }

    // 2. Menus Collection
    match /menus/{menuId} {
      allow read, write: if isValidId(menuId);
    }

    // 3. Transactions Collection
    match /transactions/{transactionId} {
      allow read, write: if isValidId(transactionId);
    }

    // 4. Transaction Details Collection
    match /transaction_details/{detailId} {
      allow read, write: if isValidId(detailId);
    }

    // 5. Activity Logs Collection
    match /activity_log/{logId} {
      allow read, write: if isValidId(logId);
    }

    // 6. Settings Collection
    match /settings/{settingsId} {
      allow read, write: if isValidId(settingsId);
    }
  }
}
